import = [
  "/Users/rohitmanivel/.npm/_npx/808b709e6234a442/node_modules/alacritty-themes/themes/Gruvbox-Dark.toml"
]

[cursor]
blink_interval = 750
blink_timeout = 0
thickness = 0.15

  [cursor.style]
  shape = "Block"
  blinking = "On"

[env]
TERM = "xterm-256color"

[font]
size = 14

  [font.glyph_offset]
  y = 9

  [font.normal]
  family = "JetBrainsMono Nerd Font"

  [font.offset]
  y = 16

[scrolling]
history = 2_000

[window]
decorations = "Buttonless"
opacity = 0.95

  [window.dimensions]
  columns = 130
  lines = 40

  [window.padding]
  x = 5
  y = 5
